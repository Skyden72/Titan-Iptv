{
  "name": "zenith-iptv-player",
  "productName": "Zenith IPTV Player",
  "version": "1.0.0",
  "description": "A modern, sleek IPTV player for Windows",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "build:win": "npm run build && electron-builder --win --config builder.json",
    "pack:portable": "npm run build && electron-builder --win --config builder.json -c.nsis.oneClick=false -c.nsis.allowToChangeInstallationDirectory=true"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.24.1",
    "undici": "^6.19.2",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^29.1.5",
    "electron-builder": "^24.13.3",
    "http-proxy-middleware": "^3.0.0",
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "wait-on": "^7.2.0"
  }
}
